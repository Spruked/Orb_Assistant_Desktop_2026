{
  "name": "cali-ucm-4-core",
  "version": "2.1.0",
  "description": "Electron UI for the Platinum ORB Desktop Assistant reference system",
  "main": "main/main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "start:instance": "bash ../scripts/launch_orb_instance.sh",
    "dev": "node scripts/start-electron.js --inspect",
    "check:dock": "node --check src/ui/orb-dock-station-substrate.js && node --check main/main.js && node --check main/preload.js && node --check main/orb-bridge.js",
    "check:runtime": "node --check src/cali-launcher.js && npm run test:orb",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish=never",
    "postinstall": "electron-builder install-app-deps",
    "test:orb": "python -m py_compile src/core-bridges/cali.py src/core-bridges/kaygee.py src/core-bridges/caleon.py src/core-bridges/cali_x_one.py src/core-bridges/ucm_core_ecm.py",
    "dev:orb": "npm start"
  },
  "dependencies": {
    "python-shell": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "kill-port": "^2.0.1",
    "ws": "^8.15.1"
  },
  "build": {
    "appId": "com.orbs.platinum.desktop",
    "productName": "Platinum ORB Desktop Assistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "src/**/*",
      "node_modules/**/*",
      "cjs-build/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
